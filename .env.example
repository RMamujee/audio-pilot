# Last.fm — free API key at https://www.last.fm/api/account/create
# Provides rich genre/mood tags for millions of artists
LASTFM_API_KEY=your_lastfm_api_key_here

# Spotify — create an app at https://developer.spotify.com/dashboard
# Provides official genre labels for all artists in Spotify's catalog
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: HuggingFace Space URL for semantic embedding model
# (bypasses local fallback entirely)
HF_SPACE_URL=
